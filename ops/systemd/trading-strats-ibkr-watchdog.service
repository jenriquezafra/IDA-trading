[Unit]
Description=Trading Strats IBKR Gateway watchdog
Wants=network-online.target
After=network-online.target trading-strats-ibgateway.service

[Service]
Type=oneshot
User=trader
Group=trader
WorkingDirectory=/opt/trading-strats/app
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/trading-strats/app/.venv/bin/python -m src.execution.ibkr_watchdog --config /opt/trading-strats/app/configs/execution/ibkr_watchdog.yaml
